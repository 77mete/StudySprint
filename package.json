{
  "name": "studysprint",
  "private": true,
  "workspaces": [
    "client",
    "client/src/shared",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev -w @studysprint/client",
    "build": "npm run build -w @studysprint/client",
    "build:server": "npm run build -w @studysprint/shared && npm run build -w @studysprint/server",
    "start:server": "npm run start -w @studysprint/server"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}