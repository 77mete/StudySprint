{
  "version": 2,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://studysprintserver-production.up.railway.app/api/:path*"
    },
    {
      "source": "/socket.io/:path*",
      "destination": "https://studysprintserver-production.up.railway.app/socket.io/:path*"
    },
    {
      "source": "/socket.io/",
      "destination": "https://studysprintserver-production.up.railway.app/socket.io/"
    },
    {
      "source": "/socket.io",
      "destination": "https://studysprintserver-production.up.railway.app/socket.io"
    },
    {
      "source": "/music/:path*",
      "destination": "https://studysprintserver-production.up.railway.app/music/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
