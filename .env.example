# --- Sunucu (server/) — sürekli çalışan Node + Socket.io burada ---
# Supabase: Project Settings → Database → Connection string (URI), şifreyi URL-encode edin
# Örnek: postgresql://postgres.xxxx:ŞİFRE@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Prisma migrate için bazen doğrudan 5432 gerekir; pooler yerine "Direct connection" kullanın
DATABASE_URL=

# JWT imzalama (üretimde güçlü ve gizli tutun)
JWT_SECRET=

PORT=3001
# Virgülle ayırın: yerel + Vercel üretim (Socket.io CORS)
CLIENT_ORIGIN=http://localhost:5173,https://study-sprint-black.vercel.app

# Vercel: Project Settings → Root Directory = StudySprint (veya yalnızca client/ kullanıyorsanız Root = client)
# Build ayarları vercel.json içinde; Install/Build override'ı dashboardda boş bırakın.

# --- İstemci (Vercel Environment Variables) ---
# Üretimde REST + WebSocket bu URL'e gider (Railway, Render, Fly vb. — Vercel üzerinde Socket.io çalışmaz)
# VITE_BACKEND_URL=https://your-api.up.railway.app
